# Copy this file to .env.local and fill in your keys

# ── API Security (Phase 0) ────────────────────────────────────────────────────
# Must match FORGE_API_KEY in lead-agent/.env
FORGE_API_KEY=generate_a_long_random_string_here
FORGE_API_URL=http://localhost:8000
# Set to false only for local debugging without Supabase login
FORGE_ROUTE_AUTH_ENABLED=true
# Comma-separated Supabase user UUIDs allowed to use /admin and /api/forge/*
FORGE_ADMIN_USER_IDS=your_supabase_user_uuid_here

# ── AI Generation (required for AI mode) ─────────────────────────────────────
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Web Scraping (optional — but improves results) ────────────────────────────
# Get at: firecrawl.dev
# Without this, AI generates from name + location alone (still works great)
FIRECRAWL_API_KEY=fc-your_key_here

# ── Email Outreach (required for send email feature) ─────────────────────────
# Get at: resend.com (free tier = 3,000 emails/month)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=outreach@yourdomain.com

# ── Database + Auth (required for user accounts) ──────────────────────────────
# Get at: supabase.com — create a project, go to Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Payments (required for Pro subscriptions) ─────────────────────────────────
# Get at: dashboard.stripe.com — no monthly fee, 2.9% + 30¢ per transaction
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ── Stripe Products (set after creating products in Stripe dashboard) ─────────
STRIPE_PRO_PRICE_ID=price_your_pro_price_id_here
