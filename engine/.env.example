# FORGE Engine — copy to .env and fill in values. Never commit .env.

# ── API Security (Phase 0 — required when FORGE_AUTH_ENABLED=true) ─────────────
FORGE_API_KEY=generate_a_long_random_string_here
FORGE_AUTH_ENABLED=true
FORGE_API_PORT=8000

# ── Flask Platform ────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=generate_a_long_random_string_here
ADMIN_PASSWORD=change_me_strong_password
PORT=8080
TEST_MODE=true
MY_TEST_EMAIL=you@example.com

# ── Google Places (lead scraping) ─────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ── Gmail (outreach — migrate to Resend in Phase 5) ───────────────────────────
GMAIL_SENDER=
GMAIL_APP_PASSWORD=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ── Optional ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GITHUB_USERNAME=
UNSPLASH_ACCESS_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
MY_PHONE=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Storage (Phase 2) ─────────────────────────────────────────────────────────
# csv = leads.csv / log.csv (default, rollback-safe)
# postgres = Supabase as source of truth (requires migration 003 + keys above)
STORAGE_BACKEND=csv

# ── Celery / Redis (Phase 3) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
USE_CELERY=true
# FORGE_ROLE=api          # api | worker | beat (set per Railway service)
# CELERY_BROKER_URL=      # optional override; defaults to REDIS_URL
# CELERY_RESULT_BACKEND=  # optional override; defaults to REDIS_URL

# ── Pipeline dashboard (local dev only — deprecated) ──────────────────────────
FORGE_DASHBOARD_ENABLED=true
FORGE_DASHBOARD_API_KEY=use_same_value_as_FORGE_API_KEY_for_post_routes